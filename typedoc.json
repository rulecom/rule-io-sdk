{
  "entryPoints": [
    "packages/client/src/index.ts",
    "packages/rcml/src/index.ts",
    "packages/sdk/src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "apps/docs/src/api",
  "plugin": ["typedoc-plugin-markdown"],
