{
  "name": "vendor-shopify",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vendor-shopify/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/packages/vendor-shopify",
        "main": "packages/vendor-shopify/src/index.ts",
        "tsConfig": "packages/vendor-shopify/tsconfig.lib.json",
        "assets": [
          {
            "input": "./packages/vendor-shopify",
            "glob": "*.md",
            "output": "./"
          },
          {
            "input": "./packages/vendor-shopify/src/templates",
            "glob": "*.xml",
            "output": "./src/templates"
          }
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
