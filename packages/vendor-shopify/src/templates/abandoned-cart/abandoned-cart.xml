<rcml>
  <rc-head>
    <rc-preview><?copy preheader?></rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <?if logoUrl?>
      <rc-section>
        <rc-column padding="0 20px">
          <rc-logo rc-class="rcml-logo-style rc-initial-logo" width="96px" padding="20px 0"/>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Greeting + message + reminder -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style"><?copy greetingHeading firstNameCustomField=recipient.firstName?></rc-heading>
        <rc-text rc-class="rcml-p-style" align="center"><?copy message?></rc-text>
        <rc-text rc-class="rcml-p-style" align="center"><?copy reminder?></rc-text>
      </rc-column>
    </rc-section>

    <!-- Cart line items loop -->
    <?if cart.products?>
      <rc-section padding="0">
        <rc-column padding="0 20px">
          <rc-divider padding="10px 0"/>
        </rc-column>
      </rc-section>
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-heading rc-class="rcml-h2-style"><?copy lineItemsHeading?></rc-heading>
        </rc-column>
      </rc-section>
      <rc-loop loop-type="custom-field" loop-value="@{cart.products.source.id}" loop-max-iterations="20">
        <rc-section padding="10px 0">
          <rc-column padding="0 20px">
            <rc-text rc-class="rcml-p-style"><?copy itemNameLine itemNameLoopValue=cart.products.itemName?></rc-text>
            <?if cart.products.itemSku?>
              <rc-text rc-class="rcml-p-style"><?copy itemSkuLine itemSkuLoopValue=cart.products.itemSku?></rc-text>
            <?endif?>
            <?if cart.products.itemQuantity?>
              <rc-text rc-class="rcml-p-style"><?copy itemQtyLine itemQtyLoopValue=cart.products.itemQuantity?></rc-text>
            <?endif?>
            <?if cart.products.itemPrice?>
              <rc-text rc-class="rcml-p-style"><?copy itemUnitPriceLine itemUnitPriceLoopValue=cart.products.itemPrice?></rc-text>
            <?endif?>
          </rc-column>
        </rc-section>
      </rc-loop>
    <?endif?>

    <!-- Cart total row -->
    <?if cart.totalPrice?>
      <rc-section padding="0">
        <rc-column padding="0 20px">
          <rc-divider padding="10px 0"/>
        </rc-column>
      </rc-section>
      <rc-section padding="10px 0" rc-class="rcml-brand-color">
        <rc-column padding="0 20px">
          <rc-text rc-class="rcml-p-style"><?copy totalRow totalPriceCustomField=cart.totalPrice?></rc-text>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button href="@{cart.url}" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style"><?copy ctaButton?></rc-button>
      </rc-column>
    </rc-section>

    <!-- Social icons (when theme.links populated) -->
    <?if socialLinks?>
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-social align="center">
            <?for let link of socialLinks?>
              <rc-social-element name="@{link.type}" href="@{link.url}"/>
            <?endfor?>
          </rc-social>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Footer -->
    <rc-section padding="20px 0px 20px 0px">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" font-size="@{footer.fontSize}" color="@{footer.textColor}" rc-class="rcml-p-style"><?copy footerLinks?></rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" line-height="120%" color="@{footer.textColor}" font-size="@{footer.fontSize}"><?copy certifiedByRule?></rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
