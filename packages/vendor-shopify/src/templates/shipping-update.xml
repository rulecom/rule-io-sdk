<rcml>
  <rc-head>
    <rc-preview>{{ text.preheader }}</rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <rc-section *ngIf="theme.images.logo?.url">
      <rc-column padding="0 20px">
        <rc-logo rc-class="rcml-logo-style rc-initial-logo" [src]="theme.images.logo.url" width="96px" padding="20px 0"/>
      </rc-column>
    </rc-section>

    <!-- Heading + greeting -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style">{{ text.heading }}</rc-heading>
        <rc-text rc-class="rcml-p-style">{{ text.greeting }} {{ field('firstName') }}, {{ text.message }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Status tracker (3-step; shown when all three labels supplied) -->
    <rc-section *ngIf="hasStatusTracker" padding="10px 0">
      <rc-column *ngFor="let step of statusSteps" [width]="step.width" [background-color]="step.bg" padding="14px 8px" vertical-align="middle">
        <rc-text align="center" rc-class="rcml-p-style">:font[{{ step.label }}]{color="{{ step.fg }}" font-weight="700"}</rc-text>
      </rc-column>
    </rc-section>
    <rc-section *ngIf="hasStatusTracker" padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Seller info (company, VAT) -->
    <rc-section *ngIf="hasSellerRows" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.companyLabel &amp;&amp; fieldNames.companyName" rc-class="rcml-p-style">{{ text.companyLabel }}: {{ field('companyName') }}</rc-text>
        <rc-text *ngIf="text.vatLabel &amp;&amp; fieldNames.vatNumber" rc-class="rcml-p-style">{{ text.vatLabel }}: {{ field('vatNumber') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Order details (orderRef, orderDate, paymentMethod, customerEmail) -->
    <rc-section *ngIf="hasOrderDetailRows" padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.orderRefLabel" rc-class="rcml-p-style">{{ text.orderRefLabel }}: {{ field('orderRef') }}</rc-text>
        <rc-text *ngIf="text.orderDateLabel &amp;&amp; fieldNames.orderDate" rc-class="rcml-p-style">{{ text.orderDateLabel }}: {{ field('orderDate') }}</rc-text>
        <rc-text *ngIf="text.paymentMethodLabel &amp;&amp; fieldNames.paymentMethod" rc-class="rcml-p-style">{{ text.paymentMethodLabel }}: {{ field('paymentMethod') }}</rc-text>
        <rc-text *ngIf="text.customerEmailLabel &amp;&amp; fieldNames.customerEmail" rc-class="rcml-p-style">{{ text.customerEmailLabel }}: {{ field('customerEmail') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Shipping details (address, carrier, tracking, estimated delivery) -->
    <rc-section *ngIf="hasShippingRows" padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.shippingAddressLabel &amp;&amp; fieldNames.shippingAddress" rc-class="rcml-p-style">{{ text.shippingAddressLabel }}: {{ field('shippingAddress') }}</rc-text>
        <rc-text *ngIf="text.carrierLabel &amp;&amp; fieldNames.shippingCarrier" rc-class="rcml-p-style">{{ text.carrierLabel }}: {{ field('shippingCarrier') }}</rc-text>
        <rc-text *ngIf="text.trackingLabel &amp;&amp; fieldNames.trackingNumber" rc-class="rcml-p-style">{{ text.trackingLabel }}: {{ field('trackingNumber') }}</rc-text>
        <rc-text *ngIf="text.estimatedDeliveryLabel &amp;&amp; fieldNames.estimatedDelivery" rc-class="rcml-p-style">{{ text.estimatedDeliveryLabel }}: {{ field('estimatedDelivery') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button [href]="trackingUrl" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style">{{ text.ctaButton }}</rc-button>
      </rc-column>
    </rc-section>

    <!-- Line items heading (optional) -->
    <rc-section *ngIf="hasLineItemLoop &amp;&amp; text.lineItemsHeading" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h2-style">{{ text.lineItemsHeading }}</rc-heading>
      </rc-column>
    </rc-section>

    <!-- Line items loop -->
    <rc-loop *ngIf="hasLineItemLoop" loop-type="custom-field" [loop-value]="customFields[fieldNames.items]" loop-max-iterations="20">
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-text rc-class="rcml-p-style">{{ loopValue(fieldNames.itemName) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemSku" rc-class="rcml-p-style">{{ text.itemSkuLabel ?? 'SKU: ' }}{{ loopValue(fieldNames.itemSku) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemQuantity" rc-class="rcml-p-style">{{ text.itemQtyLabel ?? 'Qty: ' }}{{ loopValue(fieldNames.itemQuantity) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemUnitPrice" rc-class="rcml-p-style">{{ text.itemUnitPriceLabel ?? 'Unit price: ' }}{{ loopValue(fieldNames.itemUnitPrice) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemTotal" rc-class="rcml-p-style">{{ text.itemLineTotalLabel ?? 'Line total: ' }}{{ loopValue(fieldNames.itemTotal) }}</rc-text>
        </rc-column>
      </rc-section>
    </rc-loop>

    <!-- Financial summary -->
    <rc-section *ngIf="hasFinancialRows" padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.subtotalLabel &amp;&amp; fieldNames.subtotal" rc-class="rcml-p-style">{{ text.subtotalLabel }}: {{ field('subtotal') }}</rc-text>
        <rc-text *ngIf="text.discountLabel &amp;&amp; fieldNames.discountAmount" rc-class="rcml-p-style">{{ text.discountLabel }}: {{ field('discountAmount') }}</rc-text>
        <rc-text *ngIf="text.taxLabel &amp;&amp; fieldNames.taxAmount" rc-class="rcml-p-style">{{ text.taxLabel }}: {{ field('taxAmount') }}</rc-text>
        <rc-text *ngIf="text.shippingCostLabel &amp;&amp; fieldNames.shippingCost" rc-class="rcml-p-style">{{ text.shippingCostLabel }}: {{ field('shippingCost') }}</rc-text>
        <rc-text *ngIf="text.totalLabel &amp;&amp; fieldNames.totalPrice" rc-class="rcml-p-style">{{ text.totalLabel }}: {{ field('totalPrice') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Buyer details -->
    <rc-section *ngIf="hasBuyerRows" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text *ngIf="fieldNames.customerFullName" rc-class="rcml-p-style">{{ field('customerFullName') }}</rc-text>
        <rc-text *ngIf="text.billingAddressLabel &amp;&amp; fieldNames.billingAddress" rc-class="rcml-p-style">{{ text.billingAddressLabel }}: {{ field('billingAddress') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Legal section: legalText + optional returnPolicy + optional terms -->
    <rc-section *ngIf="hasLegalSection" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.legalText" rc-class="rcml-p-style" align="center">{{ text.legalText }}</rc-text>
        <rc-text *ngIf="safeReturnPolicyUrl" rc-class="rcml-p-style" align="center">:link[{{ text.returnPolicyText }}]{href="{{ safeReturnPolicyUrl }}" target="_blank"}</rc-text>
        <rc-text *ngIf="safeTermsUrl" rc-class="rcml-p-style" align="center">:link[{{ text.termsText }}]{href="{{ safeTermsUrl }}" target="_blank"}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Footer -->
    <rc-section padding="20px 0px 20px 0px">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" rc-class="rcml-p-style">:font[:link[{{ footer.viewInBrowserText ?? 'View in browser' }}]{href="[Link:WebBrowser]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"} :font[|]{font-size="{{ footer.fontSize ?? '10px' }}" color="{{ footer.textColor ?? '#666666' }}"} :font[:link[{{ footer.unsubscribeText ?? 'Unsubscribe' }}]{href="[Link:Unsubscribe]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"}</rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" font-style="normal" line-height="120%" letter-spacing="0em" [color]="footer.textColor ?? '#666666'" font-weight="400" text-decoration="none" [font-size]="footer.fontSize ?? '10px'">Certified by Rule</rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
