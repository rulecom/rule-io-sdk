<rcml>
  <rc-head>
    <rc-preview>{{ text.preheader }}</rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <rc-section *ngIf="theme.images.logo?.url">
      <rc-column padding="0 20px">
        <rc-logo rc-class="rcml-logo-style rc-initial-logo" [src]="theme.images.logo.url" width="96px" padding="20px 0"/>
      </rc-column>
    </rc-section>

    <!-- Hero banner -->
    <rc-section padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style">{{ text.heading }}</rc-heading>
      </rc-column>
    </rc-section>

    <!-- Divider -->
    <rc-section padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Greeting + message -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style">{{ text.greeting }} {{ field('firstName') }},</rc-text>
        <rc-text rc-class="rcml-p-style">{{ text.message }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Order details box -->
    <rc-section padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style">{{ text.orderRefLabel }}: {{ field('orderRef') }}</rc-text>
        <rc-text *ngIf="hasOrderDate" rc-class="rcml-p-style">{{ text.orderDateLabel }}: {{ field('orderDate') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Optional support callout -->
    <rc-section *ngIf="text.supportText" padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>
    <rc-section *ngIf="text.supportText" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style" align="center">{{ text.supportText }}</rc-text>
        <rc-text *ngIf="supportLinkHref" rc-class="rcml-p-style" align="center">:link[{{ supportLinkText }}]{href="{{ supportLinkHref }}" target="_blank"}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Divider before follow-up -->
    <rc-section padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Follow-up -->
    <rc-section padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style">{{ text.followUp }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button [href]="websiteUrl" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style">{{ text.ctaButton }}</rc-button>
      </rc-column>
    </rc-section>

    <!-- Footer -->
    <rc-section padding="20px 0px 20px 0px">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" rc-class="rcml-p-style">:font[:link[{{ footer.viewInBrowserText ?? 'View in browser' }}]{href="[Link:WebBrowser]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"} :font[|]{font-size="{{ footer.fontSize ?? '10px' }}" color="{{ footer.textColor ?? '#666666' }}"} :font[:link[{{ footer.unsubscribeText ?? 'Unsubscribe' }}]{href="[Link:Unsubscribe]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"}</rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" font-style="normal" line-height="120%" letter-spacing="0em" [color]="footer.textColor ?? '#666666'" font-weight="400" text-decoration="none" [font-size]="footer.fontSize ?? '10px'">Certified by Rule</rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
