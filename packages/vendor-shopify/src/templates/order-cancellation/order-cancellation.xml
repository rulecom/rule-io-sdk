<rcml>
  <rc-head>
    <rc-preview><?copy preheader preheader=text.preheader?></rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <?if hasLogo?>
      <rc-section>
        <rc-column padding="0 20px">
          <rc-logo rc-class="rcml-logo-style rc-initial-logo" src="@{logoUrl}" width="96px" padding="20px 0"/>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Hero banner -->
    <rc-section padding="20px 0" background-color="@{secondaryBg}">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style"><?copy heading heading=text.heading?></rc-heading>
      </rc-column>
    </rc-section>

    <!-- Divider -->
    <rc-section padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Greeting + message -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style"><?copy greetingLine greeting=text.greeting firstNameLabel=fieldNames.firstName firstNameId=customFieldsById.firstName?></rc-text>
        <rc-text rc-class="rcml-p-style"><?copy message message=text.message?></rc-text>
      </rc-column>
    </rc-section>

    <!-- Order details box -->
    <rc-section padding="20px 0" background-color="@{secondaryBg}">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style"><?copy orderRefRow orderRefLabel=text.orderRefLabel orderRefName=fieldNames.orderRef orderRefId=customFieldsById.orderRef?></rc-text>
        <?if hasOrderDate?>
          <rc-text rc-class="rcml-p-style"><?copy orderDateRow orderDateLabel=text.orderDateLabel orderDateName=fieldNames.orderDate orderDateId=customFieldsById.orderDate?></rc-text>
        <?endif?>
      </rc-column>
    </rc-section>

    <!-- Optional support callout -->
    <?if hasSupportText?>
      <rc-section padding="0">
        <rc-column padding="0 20px">
          <rc-divider padding="10px 0"/>
        </rc-column>
      </rc-section>
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-text rc-class="rcml-p-style" align="center"><?copy supportText supportText=text.supportText?></rc-text>
          <?if hasSupportLink?>
            <rc-text rc-class="rcml-p-style" align="center"><?copy supportLink linkText=supportLinkText linkHref=supportLinkHref?></rc-text>
          <?endif?>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Divider before follow-up -->
    <rc-section padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Follow-up -->
    <rc-section padding="10px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style"><?copy followUp followUp=text.followUp?></rc-text>
      </rc-column>
    </rc-section>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button href="@{websiteUrl}" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style"><?copy ctaButton ctaButton=text.ctaButton?></rc-button>
      </rc-column>
    </rc-section>

    <!-- Footer -->
    <rc-section padding="20px 0px 20px 0px">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" rc-class="rcml-p-style"><?copy footerLinks viewInBrowserText=footer.viewInBrowserText unsubscribeText=footer.unsubscribeText fontSize=footer.fontSize textColor=footer.textColor?></rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" font-style="normal" line-height="120%" letter-spacing="0em" color="@{footer.textColor}" font-weight="400" text-decoration="none" font-size="@{footer.fontSize}"><?copy certifiedByRule?></rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
