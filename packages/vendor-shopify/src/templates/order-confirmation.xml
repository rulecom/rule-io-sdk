<rcml>
  <rc-head>
    <rc-preview>{{ text.preheader }}</rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <rc-section *ngIf="theme.images.logo?.url">
      <rc-column padding="0 20px">
        <rc-logo rc-class="rcml-logo-style rc-initial-logo" [src]="theme.images.logo.url" width="96px" padding="20px 0"/>
      </rc-column>
    </rc-section>

    <!-- Greeting + intro -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style">{{ text.greeting }}, {{ field('firstName') }}</rc-heading>
        <rc-text rc-class="rcml-p-style">{{ text.intro }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Hero heading: "{prefix} {orderRef} {suffix}" when either side supplied -->
    <rc-section *ngIf="text.heroHeadingPrefix || text.heroHeadingSuffix" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style">{{ text.heroHeadingPrefix ? text.heroHeadingPrefix + ' ' : '' }}{{ field('orderRef') }}{{ text.heroHeadingSuffix ? ' ' + text.heroHeadingSuffix : '' }}</rc-heading>
      </rc-column>
    </rc-section>

    <!-- Two-column order meta row (orderRef + orderDate) — shown instead of single orderRef row when orderDate mapped -->
    <rc-section *ngIf="hasOrderMetaRow" padding="10px 0">
      <rc-column width="50%">
        <rc-text rc-class="rcml-p-style">{{ text.orderRefLabel }}: {{ field('orderRef') }}</rc-text>
      </rc-column>
      <rc-column width="50%">
        <rc-text rc-class="rcml-p-style">{{ text.orderDateLabel }}: {{ field('orderDate') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Details box (always present — holds heading + optional rows + conditional total) -->
    <rc-section padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h2-style">{{ text.detailsHeading }}</rc-heading>
        <rc-text *ngIf="!hasOrderMetaRow" rc-class="rcml-p-style">{{ text.orderRefLabel }}: {{ field('orderRef') }}</rc-text>
        <rc-text *ngIf="text.paymentMethodLabel &amp;&amp; fieldNames.paymentMethod" rc-class="rcml-p-style">{{ text.paymentMethodLabel }}: {{ field('paymentMethod') }}</rc-text>
        <rc-text *ngIf="hasInlineItemsRow" rc-class="rcml-p-style">{{ text.itemsLabel }}: {{ field('items') }}</rc-text>
        <rc-text *ngIf="!hasFinancialSummary" rc-class="rcml-p-style">{{ text.totalLabel }}: {{ field('totalPrice') }}</rc-text>
        <rc-text *ngIf="hasInlineShippingRow" rc-class="rcml-p-style">{{ text.shippingLabel }}: {{ field('shippingAddress') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Divider before line items loop -->
    <rc-section *ngIf="hasLineItemLoop" padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>

    <!-- Optional line-items heading -->
    <rc-section *ngIf="hasLineItemLoop &amp;&amp; text.lineItemsHeading" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h2-style">{{ text.lineItemsHeading }}</rc-heading>
      </rc-column>
    </rc-section>

    <!-- Line items loop -->
    <rc-loop *ngIf="hasLineItemLoop" loop-type="custom-field" [loop-value]="customFields[fieldNames.items]" loop-max-iterations="20">
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-text rc-class="rcml-p-style">{{ loopValue(fieldNames.itemName) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemSku" rc-class="rcml-p-style">{{ text.itemSkuLabel ?? 'SKU: ' }}{{ loopValue(fieldNames.itemSku) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemQuantity" rc-class="rcml-p-style">{{ text.itemQtyLabel ?? 'Qty: ' }}{{ loopValue(fieldNames.itemQuantity) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemUnitPrice" rc-class="rcml-p-style">{{ text.itemUnitPriceLabel ?? 'Price: ' }}{{ loopValue(fieldNames.itemUnitPrice) }}</rc-text>
          <rc-text *ngIf="fieldNames.itemTotal" rc-class="rcml-p-style">{{ text.itemSubtotalLabel ?? 'Subtotal: ' }}{{ loopValue(fieldNames.itemTotal) }}</rc-text>
        </rc-column>
      </rc-section>
    </rc-loop>

    <!-- Financial summary (shown when any financial field+label is mapped) -->
    <rc-section *ngIf="hasFinancialSummary" padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>
    <rc-section *ngIf="hasFinancialSummary" padding="20px 0" [background-color]="theme.colors.secondary?.hex">
      <rc-column padding="0 20px">
        <rc-text *ngIf="text.subtotalLabel &amp;&amp; fieldNames.subtotal" rc-class="rcml-p-style">{{ text.subtotalLabel }}: {{ field('subtotal') }}</rc-text>
        <rc-text *ngIf="text.discountLabel &amp;&amp; fieldNames.discountAmount" rc-class="rcml-p-style">{{ text.discountLabel }}: {{ field('discountAmount') }}</rc-text>
        <rc-text *ngIf="text.taxLabel &amp;&amp; fieldNames.taxAmount" rc-class="rcml-p-style">{{ text.taxLabel }}: {{ field('taxAmount') }}</rc-text>
        <rc-text *ngIf="text.shippingCostLabel &amp;&amp; fieldNames.shippingCost" rc-class="rcml-p-style">{{ text.shippingCostLabel }}: {{ field('shippingCost') }}</rc-text>
        <rc-text rc-class="rcml-p-style">{{ text.totalLabel }}: {{ field('totalPrice') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- Shipping address block (extended address fields mapped) -->
    <rc-section *ngIf="hasExtendedAddress" padding="0">
      <rc-column padding="0 20px">
        <rc-divider padding="10px 0"/>
      </rc-column>
    </rc-section>
    <rc-section *ngIf="hasExtendedAddress" padding="10px 0">
      <rc-column padding="0 20px">
        <rc-heading *ngIf="shippingAddressHeading" rc-class="rcml-h4-style">{{ shippingAddressHeading }}</rc-heading>
        <rc-text rc-class="rcml-p-style">{{ field('shippingAddress') }}</rc-text>
        <rc-text *ngIf="fieldNames.shippingAddress2" rc-class="rcml-p-style">{{ field('shippingAddress2') }}</rc-text>
        <rc-text *ngIf="fieldNames.shippingCity || fieldNames.shippingZip" rc-class="rcml-p-style">{{ fieldNames.shippingZip ? field('shippingZip') : '' }}{{ fieldNames.shippingZip &amp;&amp; fieldNames.shippingCity ? ' ' : '' }}{{ fieldNames.shippingCity ? field('shippingCity') : '' }}</rc-text>
        <rc-text *ngIf="fieldNames.shippingCountryCode" rc-class="rcml-p-style">{{ field('shippingCountryCode') }}</rc-text>
      </rc-column>
    </rc-section>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button [href]="websiteUrl" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style">{{ text.ctaButton }}</rc-button>
      </rc-column>
    </rc-section>

    <!-- Footer -->
    <rc-section padding="20px 0px 20px 0px">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" rc-class="rcml-p-style">:font[:link[{{ footer.viewInBrowserText ?? 'View in browser' }}]{href="[Link:WebBrowser]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"} :font[|]{font-size="{{ footer.fontSize ?? '10px' }}" color="{{ footer.textColor ?? '#666666' }}"} :font[:link[{{ footer.unsubscribeText ?? 'Unsubscribe' }}]{href="[Link:Unsubscribe]" target="_blank" no-tracked="true"}]{font-size="{{ footer.fontSize ?? '10px' }}" text-decoration="underline" color="{{ footer.textColor ?? '#666666' }}"}</rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" font-style="normal" line-height="120%" letter-spacing="0em" [color]="footer.textColor ?? '#666666'" font-weight="400" text-decoration="none" [font-size]="footer.fontSize ?? '10px'">Certified by Rule</rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
