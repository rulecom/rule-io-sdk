    "CHANGELOG.md"
  ],
  "keywords": ["rule.io", "sdk", "templates", "xml", "angular"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rulecom/rule-io-sdk.git",
    "directory": "packages/templates"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
