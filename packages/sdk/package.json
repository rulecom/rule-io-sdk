{
  "name": "@rulecom/sdk",
  "version": "0.4.0-beta.1",
  "description": "TypeScript SDK for Rule.io email marketing API with RCML template builders — meta-package re-exporting @rulecom/rcml and @rulecom/client.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "rule.io",
    "email",
    "marketing",
    "api",
    "sdk",
    "rcml",
    "email-templates"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rulecom/rule-io-sdk.git",
    "directory": "packages/sdk"
  },
  "dependencies": {
    "@rulecom/rcml": "0.4.0-beta.1",
    "@rulecom/client": "0.4.0-beta.1"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
