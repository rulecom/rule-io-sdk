<rcml>
  <rc-head>
    <rc-preview><?copy preheader?></rc-preview>
  </rc-head>
  <rc-body>
    <!-- Logo -->
    <?if logoUrl?>
      <rc-section>
        <rc-column padding="0 20px">
          <rc-logo rc-class="rcml-logo-style rc-initial-logo" width="96px" padding="20px 0"/>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Greeting + intro -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h1-style"><?copy greetingHeading firstName=recipient.firstName?></rc-heading>
        <rc-text rc-class="rcml-p-style"><?copy intro?></rc-text>
      </rc-column>
    </rc-section>

    <!-- Tax summary details -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-heading rc-class="rcml-h3-style"><?copy detailsHeading?></rc-heading>
        <rc-text rc-class="rcml-p-style"><?copy yearRow year=tax.year?></rc-text>
        <?if tax.currency?>
          <rc-text rc-class="rcml-p-style"><?copy totalRowWithCurrency total=tax.totalLifetimeAmount currency=tax.currency?></rc-text>
        <?endif?>
        <?if !tax.currency?>
          <rc-text rc-class="rcml-p-style"><?copy totalRow total=tax.totalLifetimeAmount?></rc-text>
        <?endif?>
        <?if tax.currency?>
          <rc-text rc-class="rcml-p-style"><?copy deductibleRowWithCurrency deductible=tax.taxDeductibleAmount currency=tax.currency?></rc-text>
        <?endif?>
        <?if !tax.currency?>
          <rc-text rc-class="rcml-p-style"><?copy deductibleRow deductible=tax.taxDeductibleAmount?></rc-text>
        <?endif?>
      </rc-column>
    </rc-section>

    <!-- Disclaimer -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style"><?copy disclaimer?></rc-text>
      </rc-column>
    </rc-section>

    <!-- CTA -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-button href="@{websiteUrl}" align="center" border="none" border-radius="8px" inner-padding="10px 16px" padding="0 0 20px 0" text-align="center" vertical-align="middle" rc-class="rcml-label-style"><?copy ctaButton?></rc-button>
      </rc-column>
    </rc-section>

    <!-- Sign-off -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text rc-class="rcml-p-style"><?copy signOff?></rc-text>
      </rc-column>
    </rc-section>

    <!-- Social icons -->
    <?if socialLinks?>
      <rc-section padding="10px 0">
        <rc-column padding="0 20px">
          <rc-social align="center">
            <?for let link of socialLinks?>
              <rc-social-element name="@{link.type}" href="@{link.url}"/>
            <?endfor?>
          </rc-social>
        </rc-column>
      </rc-section>
    <?endif?>

    <!-- Footer -->
    <rc-section padding="20px 0">
      <rc-column padding="0 20px">
        <rc-text align="center" padding="0px 0px 10px 0px" font-size="@{footer.fontSize}" color="@{footer.textColor}" rc-class="rcml-p-style"><?copy footerLinks?></rc-text>
        <rc-text align="center" padding="10px 0px 0px 0px" font-family="'Helvetica', sans-serif" line-height="120%" color="@{footer.textColor}" font-size="@{footer.fontSize}"><?copy certifiedByRule?></rc-text>
      </rc-column>
    </rc-section>
  </rc-body>
</rcml>
