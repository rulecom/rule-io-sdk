{
  "name": "rule-io-sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for Rule.io email marketing API with RCML template builders",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "preversion": "npm run type-check && npm run lint && npm run test",
    "prepare": "[ -f node_modules/.bin/tsup ] && npm run build || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rule.io",
    "email",
    "marketing",
    "api",
    "sdk",
    "rcml",
    "email-templates"
  ],
  "author": "Rule Communication - Nordic AB",
  "license": "MIT",
  "homepage": "https://github.com/rulecom/rule-io-sdk#readme",
  "bugs": {
    "url": "https://github.com/rulecom/rule-io-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulecom/rule-io-sdk.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
