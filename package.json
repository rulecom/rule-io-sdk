{
  "name": "rule-io-sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for Rule.io email marketing API with RCML template builders",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepare": "[ -f node_modules/.bin/tsup ] && npm run build || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rule.io",
    "email",
    "marketing",
    "api",
    "sdk",
    "rcml",
    "email-templates"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/swesam/rule-io-sdk.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
